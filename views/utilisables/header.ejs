<!-- =============================================
     HEADER - VERSION NETTOYÉE
     ============================================= -->
<header class="header" id="header">
  <div class="header-container">

    <!-- LOGO -->
    <div class="logo">
      <a href="/" aria-label="Retour à l'accueil - DevPioneers">
        <img src="/images/logo.png" alt="Logo DevPioneers" onerror="this.style.display='none'">
        <span class="logo-text">Dev<span>Pioneers</span></span>
      </a>
    </div>

    <!-- NAVIGATION DESKTOP -->
    <nav class="nav-links" id="nav" role="navigation" aria-label="Navigation principale">
      <a href="/"          class="<%= active === 'home'      ? 'active' : '' %>">Accueil</a>
      <a href="/#services">Services</a>
      <a href="/portfolio" class="<%= active === 'portfolio' ? 'active' : '' %>">Réalisations</a>
      <a href="/contact"   class="<%= active === 'contact'   ? 'active' : '' %>">Contact</a>
    </nav>

    <!-- CTA DESKTOP -->
    <div class="header-right">
      <a href="/contact" class="btn-header" aria-label="Démarrer un projet">
        Démarrer
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>

  </div>
</header>

<style>
:root {
  --navy:        rgba(18,16,62,0.92);
  --navy-deep:   rgba(11,9,46,0.98);
  --accent:      #6366f1;
  --accent-soft: rgba(99,102,241,0.25);
  --accent-glow: rgba(99,102,241,0.55);
  --white:       #ffffff;
  --white-75:    rgba(255,255,255,0.75);
  --white-10:    rgba(255,255,255,0.10);
  --radius-pill: 9999px;
  --transition:  0.32s cubic-bezier(0.23,1,0.32,1);
  --transition-fast: 0.22s ease;
}

/* ===================== HEADER ===================== */
.header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 2000;
  animation: slideDown 0.7s cubic-bezier(0.23,1,0.32,1) both;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-32px); }
  to   { opacity: 1; transform: translateY(0); }
}

.header-container {
  max-width: 1240px;
  margin: 14px auto;
  padding: 0 24px;
  height: 66px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20px;
  background: var(--navy);
  backdrop-filter: blur(24px);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: var(--radius-pill);
  box-shadow: 0 2px 0 rgba(255,255,255,0.06) inset,
              0 10px 45px rgba(0,0,0,0.35);
  transition: background var(--transition), box-shadow var(--transition);
}

.header.scrolled .header-container {
  background: var(--navy-deep);
  box-shadow: 0 2px 0 rgba(255,255,255,0.05) inset,
              0 16px 55px rgba(0,0,0,0.5);
}

/* ===================== LOGO ===================== */
.logo a {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}

.logo img {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  object-fit: cover;
  border: 1px solid rgba(255,255,255,0.15);
  transition: all var(--transition);
}

.logo a:hover img {
  transform: scale(1.08) rotate(-4deg);
  box-shadow: 0 0 25px var(--accent-glow);
}

.logo-text {
  font-size: 17.8px;
  font-weight: 800;
  letter-spacing: -0.5px;
  color: var(--white);
}

.logo-text span { color: #a5b4fc; }

/* ===================== NAVIGATION ===================== */
.nav-links {
  display: flex;
  align-items: center;
  gap: 6px;
}

.nav-links a {
  color: var(--white-75);
  font-weight: 600;
  font-size: 14.5px;
  padding: 10px 20px;
  border-radius: 50px;
  text-decoration: none;
  white-space: nowrap;
  transition: all var(--transition-fast);
  position: relative;
}

.nav-links a:hover { background: rgba(255,255,255,0.10); color: var(--white); }
.nav-links a.active { background: var(--accent-soft); color: var(--white); }
.nav-links a.active::after {
  content: '';
  position: absolute;
  bottom: 6px;
  left: 50%;
  transform: translateX(-50%);
  width: 4px;
  height: 4px;
  background: #a5b4fc;
  border-radius: 50%;
}

/* ===================== CTA DESKTOP ===================== */
.header-right { display: flex; align-items: center; gap: 12px; }

.btn-header {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  padding: 12px 26px;
  border-radius: 50px;
  background: linear-gradient(135deg, #6366f1, #4338ca);
  color: white;
  font-weight: 700;
  font-size: 14.5px;
  text-decoration: none;
  box-shadow: 0 5px 20px rgba(99,102,241,0.45),
              inset 0 1px 0 rgba(255,255,255,0.25);
  transition: all var(--transition);
  position: relative;
  overflow: hidden;
}

.btn-header::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -120%;
  width: 60%;
  height: 200%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transition: left 0.65s ease;
}

.btn-header:hover::before { left: 180%; }
.btn-header:hover { transform: translateY(-3px); box-shadow: 0 14px 35px rgba(99,102,241,0.6); }
.btn-header svg { width: 15px; height: 15px; transition: transform var(--transition); }
.btn-header:hover svg { transform: translateX(4px); }

/* ===================== MOBILE ===================== */
@media (max-width: 768px) {
  .nav-links { display: none; }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const header = document.getElementById('header');

  // Effet scroll
  window.addEventListener('scroll', () => {
    header.classList.toggle('scrolled', window.scrollY > 40);
  }, { passive: true });
});
</script>