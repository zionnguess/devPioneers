<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevPioneers - Contactez-nous</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/images/logo.png">
    <style>
        :root {
            --navy: #02014a;
            --accent: #6366f1;
            --accent-dark: #4338ca;
            --white: #ffffff;
            --gray-light: #f8fafc;
            --text: #1e2937;
            --text-light: #64748b;
            --border: #e2e8f0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: "Poppins", sans-serif;
            background: var(--gray-light);
            color: var(--text);
            line-height: 1.75;
        }

        /* ===================== HERO ===================== */
        .contact-hero {
            padding: 160px 20px 130px;
            text-align: center;
            background: linear-gradient(135deg, var(--navy), #4f46e5);
            color: white;
            position: relative;
            overflow: hidden;
        }

        .contact-hero::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 180px;
            background: linear-gradient(to bottom, transparent, var(--gray-light));
        }

        .contact-hero h1 {
            font-size: clamp(44px, 7.5vw, 68px);
            font-weight: 800;
            margin-bottom: 26px;
            letter-spacing: -1.6px;
        }

        .contact-hero p {
            font-size: 19.8px;
            max-width: 780px;
            margin: 0 auto;
            opacity: 0.94;
        }

        /* ===================== WHY US ===================== */
        .why-us {
            padding: 120px 20px;
            background: white;
        }

        .why-us-container {
            max-width: 1140px;
            margin: 0 auto;
            text-align: center;
        }

        .why-us h2 {
            font-size: 41px;
            margin-bottom: 20px;
        }

        .why-us p {
            max-width: 660px;
            margin: 0 auto 60px;
            color: var(--text-light);
            font-size: 16.8px;
        }

        .why-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
            gap: 34px;
        }

        .why-card {
            padding: 40px 30px;
            border-radius: 24px;
            background: white;
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.07);
            transition: all 0.4s ease;
        }

        .why-card:hover {
            transform: translateY(-12px);
            box-shadow: 0 25px 50px rgba(99, 102, 241, 0.14);
        }

        .why-card h3 {
            color: var(--accent);
            margin-bottom: 16px;
            font-size: 21px;
            font-weight: 600;
        }

        /* ===================== WHAT WE DO ===================== */
        .what-we-do {
            padding: 120px 20px;
            background: white;
        }

        .what-we-do-container {
            max-width: 1240px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 90px;
            align-items: center;
        }

        .what-we-do-image img {
            width: 100%;
            border-radius: 28px;
            box-shadow: 0 30px 70px rgba(0, 0, 0, 0.15);
        }

        .what-we-do-text h2 {
            font-size: 42px;
            margin-bottom: 42px;
            line-height: 1.15;
        }

        .expertise-item {
            margin-bottom: 48px;
        }

        .expertise-item h3 {
            font-size: 22.5px;
            margin-bottom: 14px;
            color: var(--accent);
            font-weight: 600;
        }

        .expertise-item p {
            color: var(--text-light);
            font-size: 16px;
            line-height: 1.78;
        }

        /* ===================== FORM ===================== */
        .contact-form-section {
            max-width: 860px;
            margin: -80px auto 130px;
            padding: 60px 55px;
            background: white;
            border-radius: 30px;
            box-shadow: 0 30px 80px rgba(0, 0, 0, 0.13);
            position: relative;
            z-index: 10;
        }

        .form-message {
            text-align: center;
            padding: 16px 28px;
            margin-bottom: 34px;
            border-radius: 16px;
            background: #ecfdf5;
            color: #10b981;
            font-weight: 500;
        }

        .contact-form {
            display: grid;
            gap: 28px;
        }

        .contact-form input,
        .contact-form textarea {
            width: 100%;
            padding: 20px 24px;
            border: 1.5px solid var(--border);
            border-radius: 18px;
            font-size: 16.2px;
            transition: all 0.35s;
        }

        .contact-form input:focus,
        .contact-form textarea:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.18);
            outline: none;
        }

        .contact-form textarea {
            resize: vertical;
            min-height: 180px;
        }

        .contact-form button {
            padding: 21px;
            font-size: 17px;
            font-weight: 600;
            border: none;
            border-radius: 50px;
            background: linear-gradient(135deg, var(--accent), var(--accent-dark));
            color: white;
            cursor: pointer;
            transition: all 0.42s cubic-bezier(0.23, 1, 0.32, 1);
            margin-top: 12px;
        }

        .contact-form button:hover {
            transform: translateY(-6px);
            box-shadow: 0 22px 48px rgba(99, 102, 241, 0.5);
        }

        /* ===================== CONTACT INFO ===================== */
        .contact-info {
            max-width: 1140px;
            margin: 0 auto 140px;
            padding: 0 20px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(310px, 1fr));
            gap: 36px;
        }

        .info-box {
            background: white;
            padding: 46px 36px;
            border-radius: 26px;
            text-align: center;
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.08);
            transition: all 0.4s ease;
        }

        .info-box:hover {
            transform: translateY(-14px);
            box-shadow: 0 28px 60px rgba(99, 102, 241, 0.17);
        }

        .info-box h3 {
            color: var(--accent);
            margin-bottom: 18px;
            font-size: 20.5px;
            font-weight: 600;
        }

        .info-box p a {
            color: var(--text-light);
            text-decoration: none;
            transition: color 0.3s;
        }

        .info-box p a:hover {
            color: var(--accent);
        }

        /* ===================== RESPONSIVE ===================== */
        @media (max-width: 920px) {
            .what-we-do-container {
                grid-template-columns: 1fr;
                gap: 75px;
                text-align: center;
            }
        }

        @media (max-width: 640px) {
            .contact-hero { 
                padding: 120px 20px 100px; 
            }
            .contact-form-section {
                margin: -50px 16px 100px;
                padding: 45px 32px;
            }
            .why-us, .what-we-do {
                padding: 90px 20px;
            }
        }
    </style>
</head>
<body>

    <%- include('utilisables/header', { active: 'contact' }) %>
    <%- include('utilisables/cookies') %>

    <!-- HERO -->
    <section class="contact-hero">
        <h1>Contactez-nous</h1>
        <p>Parlons de votre projet. Nous sommes prêts à transformer vos idées en une solution digitale puissante et élégante.</p>
    </section>

    <!-- WHY US -->
    <section class="why-us">
        <div class="why-us-container">
            <h2>Pourquoi choisir DevPioneers ?</h2>
            <p>Une équipe passionnée, des livraisons rapides et un accompagnement personnalisé à chaque étape.</p>

            <div class="why-grid">
                <div class="why-card">
                    <h3>Rapidité d'exécution</h3>
                    <p>Des prototypes fonctionnels en quelques jours et des mises en production optimisées.</p>
                </div>
                <div class="why-card">
                    <h3>Sécurité & Fiabilité</h3>
                    <p>Code propre, mises à jour régulières et protection avancée de vos données.</p>
                </div>
                <div class="why-card">
                    <h3>Design & Expérience Utilisateur</h3>
                    <p>Des interfaces intuitives, modernes et conçues pour convertir vos visiteurs en clients.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- WHAT WE DO -->
    <section class="what-we-do">
        <div class="what-we-do-container">
            <div class="what-we-do-image">
                <img src="/images/contact.jpg" alt="Nos expertises en développement web">
            </div>

            <div class="what-we-do-text">
                <h2>Nos Expertises</h2>

                <div class="expertise-item">
                    <h3>Développement Web</h3>
                    <p>Sites vitrines, applications web et plateformes sur mesure, rapides, modernes et optimisées pour convertir vos visiteurs.</p>
                </div>

                <div class="expertise-item">
                    <h3>Maintenance & Évolution</h3>
                    <p>Nous assurons la sécurité, les mises à jour et l’amélioration continue de votre solution digitale.</p>
                </div>

                <div class="expertise-item">
                    <h3>Support Technique</h3>
                    <p>Un accompagnement réactif et professionnel pour résoudre rapidement tous vos besoins.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- FORM -->
    <section class="contact-form-section">
        <% if (message) { %>
            <p class="form-message"><%= message %></p>
        <% } %>

        <form action="/contact" method="POST" class="contact-form">
            <div class="form-group">
                <input type="text" name="name" placeholder="Votre nom complet" required>
            </div>
            <div class="form-group">
                <input type="email" name="email" placeholder="Votre adresse email" required>
            </div>
            <div class="form-group">
                <input type="text" name="subject" placeholder="Sujet de votre message" required>
            </div>
            <div class="form-group">
                <textarea name="message" rows="7" placeholder="Décrivez votre projet ou votre besoin en détail..." required></textarea>
            </div>

            <button type="submit">Envoyer le message</button>
        </form>
    </section>

    <!-- CONTACT INFO -->
    <section class="contact-info">
        <div class="info-box">
            <h3>Téléphone</h3>
            <p><a href="tel:+221710434772">+221 71 043 47 72</a></p>
        </div>

        <div class="info-box">
            <h3>Email</h3>
            <p><a href="mailto:devpioneershome@gmail.com">devpioneershome@gmail.com</a></p>
        </div>

        <div class="info-box">
            <h3>Horaires</h3>
            <p>Lundi - Samedi<br>9h00 - 18h00</p>
        </div>
    </section>

    <%- include('utilisables/footer') %>

</body>
</html>