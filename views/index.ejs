<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DevPioneers - Accueil</title>
   <style>
/* RESET */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Poppins", sans-serif;
}

body {
    background: #ffffff;
    color: #222;
    overflow-x: hidden;
}

/* ------------------------------ */
/* HERO SECTION */
/* ------------------------------ */

.hero {
    margin-top: 75px;
    min-height: 90vh;
    width: 100%;
    background: url('/images/home.jpg') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 40px;
    position: relative;
    text-align: center;
}

.hero::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px);
    z-index: 1;
}

.hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    color: white;
    animation: fadeInUp 1s ease forwards;
}

.hero-content h1 {
    font-size: 64px;
    font-weight: 800;
    margin-bottom: 20px;
}

.hero-content p {
    font-size: 20px;
    line-height: 1.6;
    margin-bottom: 35px;
    color: #f3f3f3;
}

/* CTA Buttons */
.btn-cta,
.btn-cta-outline {
    padding: 14px 28px;
    border-radius: 40px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: all .3s ease;
    margin: 0 10px;
}

.btn-cta {
    background:#02014a;;
    color: white;
}

.btn-cta:hover {
    background: #02014a;;
}

.btn-cta-outline {
    border: 2px solid #fff;
    color: white;
}

.btn-cta-outline:hover {
    background: white;
    color: #111;
}

/* Animation Keyframes */
@keyframes fadeInUp {
    0% { opacity: 0; transform: translateY(30px); }
    100% { opacity: 1; transform: translateY(0); }
}

/* ------------------------------ */
/* SERVICES SECTION */
/* ------------------------------ */

.services {
    padding: 100px 40px;
    background: #fafafa;
    text-align: center;
}

.services h2 {
    font-size: 42px;
    margin-bottom: 40px;
    font-weight: 700;
    color: #1a1a1a;
}

.service-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 35px;
    max-width: 1200px;
    margin: auto;
}

.card {
    background: white;
    border-radius: 16px;
    padding: 35px 25px;
    box-shadow: 0px 10px 30px rgba(0,0,0,0.06);
    transition: all .3s ease;
    cursor: pointer;
}

.card:hover {
    transform: translateY(-8px);
    box-shadow: 0px 18px 40px rgba(0,0,0,0.1);
}

.card img {
    height: 80px;
    margin-bottom: 20px;
}

.card h3 {
    font-size: 22px;
    margin-bottom: 12px;
    color: #1a1a1a;
    font-weight: 700;
}

.card p {
    font-size: 15px;
    color: #555;
    line-height: 1.6;
}

/* ------------------------------ */
/* RESPONSIVE */
/* ------------------------------ */

/* Tablettes */
@media (max-width: 992px) {
    .hero-content h1 {
        font-size: 48px;
    }
    .service-cards {
        grid-template-columns: 1fr 1fr;
    }
    .hero {
        padding: 0 30px;
    }
}

/* Mobiles */
@media (max-width: 768px) {
    .hero-content h1 {
        font-size: 38px;
    }
    .hero-content p {
        font-size: 18px;
    }
    .service-cards {
        grid-template-columns: 1fr;
        gap: 25px;
    }
    .hero {
        padding: 0 20px;
    }
    .btn-cta, .btn-cta-outline {
        padding: 12px 24px;
        font-size: 14px;
        margin: 8px 5px;
    }
}

/* Très petits écrans */
@media (max-width: 480px) {
    .hero-content h1 {
        font-size: 32px;
    }
    .hero-content p {
        font-size: 16px;
    }
    .services {
        padding: 60px 20px;
    }
}
</style>

</head>
<body>
    <%- include('utilisables/header') %>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-content">
            <h1>DevPioneers</h1>
            <p>Nous créons des solutions digitales modernes pour booster votre présence en ligne.</p>
            <a href="/portfolio" class="btn-cta">Voir nos projets</a>
            <a href="/contact" class="btn-cta-outline">Nous contacter</a>
        </div>
    </section>

    <!-- Services Section -->
    <section class="services">
        <h2>Nos Services</h2>
        <div class="service-cards">
            <div class="card">
                <img src="/images/service1.png" alt="Web">
                <h3>Développement Web</h3>
                <p>Création de sites web modernes et performants adaptés à vos besoins.</p>
            </div>
            <div class="card">
                <img src="/images/service2.png" alt="Mobile">
                <h3>Applications Mobiles</h3>
                <p>Applications mobiles intuitives pour iOS et Android.</p>
            </div>
            <div class="card">
                <img src="/images/service3.png" alt="Branding">
                <h3>Branding & Design</h3>
                <p>Design d'identité visuelle et branding pour renforcer votre image.</p>
            </div>
        </div>
    </section>

   <%- include('utilisables/footer') %>
</body>
</html>
