<script>
  function animateCounters() {
    const counters = document.querySelectorAll('.stats h2');
    counters.forEach(counter => {
        const target = +counter.getAttribute('data-target');
        let count = 0;
        const duration = 2000; // durée totale en ms
        const stepTime = 20;
        const increment = target / (duration / stepTime);

        const updateCounter = () => {
            count += increment;
            if(count >= target) {
                counter.innerText = counter.getAttribute('data-target') + (counter.dataset.percent === 'true' ? '%' : '');
            } else {
                counter.innerText = Math.ceil(count) + (counter.dataset.percent === 'true' ? '%' : '');
                setTimeout(updateCounter, stepTime);
            }
        };
        updateCounter();
    });
}

function checkStats() {
    const statsSection = document.querySelector('.stats');
    if(statsSection.getBoundingClientRect().top < window.innerHeight - 50) { // 50px marge
        animateCounters();
        window.removeEventListener('scroll', checkStats);
    }
}

window.addEventListener('scroll', checkStats);
window.addEventListener('load', checkStats);
</script>

