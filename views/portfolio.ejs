<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Portfolio — DevPioneers</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;800&display=swap" rel="stylesheet">

<style>
/* =============================================
   VARIABLES & RESET
   ============================================= */
:root {
  --navy:       #02014a;
  --accent:     #6366f1;
  --accent-2:   #818cf8;
  --bg:         #f4f6fc;
  --white:      #ffffff;
  --text:       #1a1a2e;
  --muted:      #6b7280;
  --card-bg:    rgba(255,255,255,0.92);
  --radius:     16px;
  --shadow-sm:  0 4px 20px rgba(0,0,0,0.07);
  --shadow-md:  0 16px 48px rgba(0,0,0,0.13);
  --transition: 0.38s cubic-bezier(0.23, 1, 0.32, 1);
}

*, *::before, *::after {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: "Poppins", sans-serif;
  background: var(--bg);
  color: var(--text);
  -webkit-font-smoothing: antialiased;
}

a { text-decoration: none; color: inherit; }

/* =============================================
   HERO
   ============================================= */
.portfolio-hero {
  position: relative;
  padding: 140px 24px 120px;
  text-align: center;
  background: linear-gradient(135deg, #02014a 0%, #2d2b8a 50%, #4f46e5 100%);
  color: var(--white);
  overflow: hidden;
}

/* Cercles lumineux décoratifs */
.portfolio-hero::before,
.portfolio-hero::after {
  content: '';
  position: absolute;
  border-radius: 50%;
  pointer-events: none;
}

.portfolio-hero::before {
  width: 600px; height: 600px;
  top: -200px; left: -150px;
  background: radial-gradient(circle, rgba(99,102,241,0.18) 0%, transparent 70%);
}

.portfolio-hero::after {
  width: 400px; height: 400px;
  bottom: -150px; right: -80px;
  background: radial-gradient(circle, rgba(129,140,248,0.15) 0%, transparent 70%);
}

.hero-inner {
  position: relative;
  z-index: 1;
  max-width: 720px;
  margin: 0 auto;
}

/* Badge au-dessus du titre */
.hero-badge {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 18px;
  border-radius: 50px;
  background: rgba(255,255,255,0.1);
  border: 1px solid rgba(255,255,255,0.2);
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.5px;
  color: rgba(255,255,255,0.9);
  margin-bottom: 28px;
  backdrop-filter: blur(8px);
}

.hero-badge span {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: #a5f3fc;
  display: inline-block;
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.5; transform: scale(0.7); }
}

.portfolio-hero h1 {
  font-size: clamp(38px, 6vw, 68px);
  font-weight: 800;
  line-height: 1.1;
  letter-spacing: -1.5px;
  margin-bottom: 20px;
}

.portfolio-hero h1 em {
  font-style: normal;
  color: var(--accent-2);
}

.portfolio-hero p {
  font-size: clamp(16px, 2vw, 19px);
  color: rgba(255,255,255,0.72);
  line-height: 1.7;
  margin-bottom: 36px;
  max-width: 560px;
  margin-left: auto;
  margin-right: auto;
}

/* Stat pills sous le texte */
.hero-stats {
  display: flex;
  justify-content: center;
  gap: 16px;
  flex-wrap: wrap;
  margin-top: 8px;
}

.hero-stat {
  padding: 10px 22px;
  border-radius: 50px;
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.15);
  font-size: 14px;
  font-weight: 600;
  backdrop-filter: blur(8px);
}

.hero-stat strong {
  color: var(--accent-2);
  margin-right: 4px;
}


/* =============================================
   FILTRES (catégories)
   ============================================= */
.filters {
  display: flex;
  justify-content: center;
  gap: 8px;
  flex-wrap: wrap;
  padding: 48px 24px 0;
  max-width: 900px;
  margin: 0 auto;
}

.filter-btn {
  padding: 9px 22px;
  border-radius: 50px;
  border: 1px solid rgba(99,102,241,0.2);
  background: var(--white);
  color: var(--muted);
  font-family: "Poppins", sans-serif;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  transition: all var(--transition);
  box-shadow: var(--shadow-sm);
}

.filter-btn:hover {
  border-color: var(--accent);
  color: var(--accent);
  transform: translateY(-2px);
}

.filter-btn.active {
  background: linear-gradient(135deg, var(--accent), #4338ca);
  color: var(--white);
  border-color: transparent;
  box-shadow: 0 6px 20px rgba(99,102,241,0.35);
}


/* =============================================
   GRILLE PROJETS
   ============================================= */
.projects-section {
  max-width: 1200px;
  margin: 0 auto;
  padding: 48px 24px 80px;
}

.projects-count {
  font-size: 13px;
  color: var(--muted);
  font-weight: 600;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  margin-bottom: 28px;
}

.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 28px;
}


/* =============================================
   CARD PROJET
   ============================================= */
.project-card {
  background: var(--card-bg);
  backdrop-filter: blur(12px);
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  border: 1px solid rgba(255,255,255,0.7);
  display: flex;
  flex-direction: column;
  transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
  position: relative;
}

.project-card:hover {
  transform: translateY(-10px);
  box-shadow: var(--shadow-md);
  border-color: rgba(99,102,241,0.2);
}

/* ── IMAGE ── */
.project-image {
  position: relative;
  height: 220px;
  overflow: hidden;
  background: linear-gradient(135deg, #e8e8f8, #d1d5f0);
  flex-shrink: 0;
}

.project-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.55s ease;
}

.project-card:hover .project-image img {
  transform: scale(1.07);
}

/* Overlay au hover */
.project-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top,
    rgba(2, 1, 74, 0.75) 0%,
    rgba(79, 70, 229, 0.4) 60%,
    transparent 100%);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 24px;
  opacity: 0;
  transition: opacity var(--transition);
}

.project-card:hover .project-overlay {
  opacity: 1;
}

.overlay-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 10px 24px;
  border-radius: 50px;
  background: var(--white);
  color: var(--navy);
  font-weight: 700;
  font-size: 13px;
  letter-spacing: 0.3px;
  transition: transform 0.2s;
}

.overlay-btn:hover { transform: scale(1.04); }

.overlay-btn svg {
  width: 13px; height: 13px;
  flex-shrink: 0;
}

/* Badge de catégorie sur l'image */
.project-badge {
  position: absolute;
  top: 14px; left: 14px;
  padding: 4px 12px;
  border-radius: 50px;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(6px);
  font-size: 11px;
  font-weight: 700;
  color: var(--accent);
  letter-spacing: 0.5px;
  text-transform: uppercase;
  border: 1px solid rgba(99,102,241,0.15);
}

/* ── CONTENU ── */
.project-content {
  padding: 22px 22px 24px;
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.project-content h3 {
  font-size: 18px;
  font-weight: 700;
  color: var(--text);
  line-height: 1.3;
}

.project-content p {
  font-size: 14px;
  color: var(--muted);
  line-height: 1.65;
  flex-grow: 1;
}

/* Tags tech */
.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 4px;
}

.project-tag {
  padding: 3px 10px;
  border-radius: 50px;
  background: rgba(99,102,241,0.08);
  color: var(--accent);
  font-size: 12px;
  font-weight: 600;
  border: 1px solid rgba(99,102,241,0.15);
}

/* Lien "Voir le projet" en bas */
.project-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 13px;
  font-weight: 700;
  color: var(--accent);
  margin-top: 6px;
  transition: gap var(--transition), color var(--transition);
}

.project-link svg {
  width: 13px; height: 13px;
  transition: transform var(--transition);
}

.project-card:hover .project-link {
  gap: 10px;
  color: #4338ca;
}

.project-card:hover .project-link svg {
  transform: translateX(2px);
}


/* =============================================
   ÉTAT VIDE
   ============================================= */
.empty-state {
  text-align: center;
  padding: 80px 24px;
  grid-column: 1 / -1;
}

.empty-state svg {
  width: 64px; height: 64px;
  color: rgba(99,102,241,0.25);
  margin-bottom: 20px;
}

.empty-state h3 {
  font-size: 20px;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 10px;
}

.empty-state p {
  color: var(--muted);
  font-size: 15px;
}


/* =============================================
   CTA FINAL
   ============================================= */
.call-to-action {
  margin: 0 24px 100px;
  padding: 72px 36px;
  background: linear-gradient(135deg, #4f46e5 0%, #02014a 100%);
  color: var(--white);
  border-radius: 24px;
  max-width: 1152px;
  margin-left: auto;
  margin-right: auto;
  text-align: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 24px 60px rgba(79,70,229,0.3);
}

/* Déco CTA */
.call-to-action::before {
  content: '';
  position: absolute;
  top: -80px; right: -80px;
  width: 320px; height: 320px;
  border-radius: 50%;
  background: rgba(255,255,255,0.05);
  pointer-events: none;
}

.call-to-action::after {
  content: '';
  position: absolute;
  bottom: -60px; left: -60px;
  width: 200px; height: 200px;
  border-radius: 50%;
  background: rgba(255,255,255,0.04);
  pointer-events: none;
}

.cta-inner {
  position: relative;
  z-index: 1;
}

.call-to-action h2 {
  font-size: clamp(26px, 4vw, 42px);
  font-weight: 800;
  letter-spacing: -0.8px;
  margin-bottom: 14px;
}

.call-to-action p {
  color: rgba(255,255,255,0.72);
  font-size: 17px;
  margin-bottom: 36px;
  max-width: 480px;
  margin-left: auto;
  margin-right: auto;
}

.cta-buttons {
  display: flex;
  justify-content: center;
  gap: 14px;
  flex-wrap: wrap;
}

.btn-cta-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 32px;
  background: var(--white);
  color: var(--navy);
  font-weight: 700;
  font-size: 15px;
  border-radius: 50px;
  transition: transform var(--transition), box-shadow var(--transition);
  box-shadow: 0 6px 20px rgba(0,0,0,0.15);
  position: relative;
  overflow: hidden;
}

.btn-cta-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.25);
}

.btn-cta-secondary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 32px;
  background: rgba(255,255,255,0.1);
  color: var(--white);
  font-weight: 700;
  font-size: 15px;
  border-radius: 50px;
  border: 1px solid rgba(255,255,255,0.25);
  backdrop-filter: blur(8px);
  transition: background var(--transition), transform var(--transition);
}

.btn-cta-secondary:hover {
  background: rgba(255,255,255,0.18);
  transform: translateY(-3px);
}


/* =============================================
   RESPONSIVE
   ============================================= */
@media (max-width: 768px) {

  .portfolio-hero {
    padding: 110px 20px 90px;
  }

  .hero-stats {
    gap: 10px;
  }

  .hero-stat {
    padding: 8px 16px;
    font-size: 13px;
  }

  .projects-grid {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .call-to-action {
    margin: 0 16px 60px;
    padding: 52px 24px;
    border-radius: 18px;
  }

  .cta-buttons {
    flex-direction: column;
    align-items: center;
  }

  .btn-cta-primary,
  .btn-cta-secondary {
    width: 100%;
    max-width: 280px;
    justify-content: center;
  }
}

@media (max-width: 480px) {
  .filters {
    gap: 6px;
    padding-top: 36px;
  }

  .filter-btn {
    padding: 8px 16px;
    font-size: 13px;
  }
}
</style>
</head>

<body>

<%- include('utilisables/header', { active: 'portfolio' }) %>

<main>

  <!-- ═══════════════════════════════════════
       HERO
       ═══════════════════════════════════════ -->
  <section class="portfolio-hero">
    <div class="hero-inner">
      <div class="hero-badge">
        <span></span>
        Nos Réalisations
      </div>
      <h1>Des projets qui <em>parlent</em> pour nous</h1>
      <p>Web, mobile, e-commerce et logiciels sur mesure — découvrez comment nous transformons les idées en produits performants.</p>
      <div class="hero-stats">
        <div class="hero-stat"><strong>+50</strong> Projets livrés</div>
        <div class="hero-stat"><strong>+30</strong> Clients satisfaits</div>
        <div class="hero-stat"><strong>5★</strong> Note moyenne</div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       FILTRES
       ═══════════════════════════════════════ -->
  <div class="filters" id="filters">
    <button class="filter-btn active" data-filter="all">Tous</button>
    <button class="filter-btn" data-filter="web">Web</button>
    <button class="filter-btn" data-filter="mobile">Mobile</button>
    <button class="filter-btn" data-filter="ecommerce">E-commerce</button>
    <button class="filter-btn" data-filter="logiciel">Logiciel</button>
  </div>

  <!-- ═══════════════════════════════════════
       GRILLE PROJETS
       ═══════════════════════════════════════ -->
  <section class="projects-section">

    <p class="projects-count" id="projectsCount">
      <!-- rempli par JS -->
    </p>

    <div class="projects-grid" id="projectsGrid">

      <% if (projets && projets.length > 0) { %>

        <% projets.forEach(p => { %>
        <div class="project-card" data-category="<%= p.category || 'web' %>">

          <!-- IMAGE + OVERLAY -->
          <div class="project-image">

            <% if (p.badge) { %>
              <span class="project-badge"><%= p.badge %></span>
            <% } else { %>
              <span class="project-badge"><%= p.category || 'Web' %></span>
            <% } %>

            <img
              src="https://image.thum.io/get/https://<%= p.url.replace(/^https?:\/\//, '') %>"
              alt="<%= p.title %>"
              loading="lazy"
              onerror="this.src='/images/default-project.jpg'">

            <div class="project-overlay">
              <a href="<%= p.url %>" target="_blank" rel="noopener" class="overlay-btn">
                Voir le projet
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="7" y1="17" x2="17" y2="7"/>
                  <polyline points="7 7 17 7 17 17"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- CONTENU -->
          <div class="project-content">
            <h3><%= p.title %></h3>
            <p><%= p.description %></p>

            <!-- Tags (optionnels) -->
            <% if (p.tags && p.tags.length) { %>
            <div class="project-tags">
              <% p.tags.forEach(tag => { %>
                <span class="project-tag"><%= tag %></span>
              <% }) %>
            </div>
            <% } %>

            <a href="<%= p.url %>" target="_blank" rel="noopener" class="project-link">
              Voir le projet
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
              </svg>
            </a>
          </div>

        </div>
        <% }) %>

      <% } else { %>

        <div class="empty-state">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
          </svg>
          <h3>Aucun projet disponible</h3>
          <p>Revenez bientôt — de nouvelles réalisations arrivent.</p>
        </div>

      <% } %>

    </div>
  </section>

  <!-- ═══════════════════════════════════════
       CTA
       ═══════════════════════════════════════ -->
  <section class="call-to-action">
    <div class="cta-inner">
      <h2>Un projet en tête ? </h2>
      <p>Parlons de votre idée et construisons ensemble quelque chose d'exceptionnel.</p>
      <div class="cta-buttons">
        <a href="/contact" class="btn-cta-primary">
          Démarrer un projet
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="15" height="15">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
        <a href="tel:+221710434772" class="btn-cta-secondary">
           Appeler directement
        </a>
      </div>
    </div>
  </section>

</main>

<%- include('utilisables/footer') %>

<!-- ═══════════════════════════════════════
     SCRIPT — Filtre de catégories
     ═══════════════════════════════════════ -->
<script>
  const filterBtns   = document.querySelectorAll('.filter-btn');
  const cards        = document.querySelectorAll('.project-card');
  const countEl      = document.getElementById('projectsCount');

  /* Met à jour le compteur de projets visibles */
  function updateCount() {
    const visible = [...cards].filter(c => c.style.display !== 'none').length;
    if (countEl) {
      countEl.textContent = visible + ' projet' + (visible > 1 ? 's' : '');
    }
  }

  /* Filtre les cartes selon la catégorie */
  function applyFilter(filter) {
    cards.forEach(card => {
      const cat = card.dataset.category || 'web';
      const show = filter === 'all' || cat === filter;

      /* Animation de sortie/entrée */
      if (show) {
        card.style.display = 'flex';
        requestAnimationFrame(() => {
          card.style.opacity = '1';
          card.style.transform = 'translateY(0)';
        });
      } else {
        card.style.opacity = '0';
        card.style.transform = 'translateY(12px)';
        setTimeout(() => { card.style.display = 'none'; }, 280);
      }
    });

    setTimeout(updateCount, 300);
  }

  /* Initialise les transitions sur chaque carte */
  cards.forEach(card => {
    card.style.transition = 'opacity 0.28s ease, transform 0.28s ease';
  });

  /* Écoute des clics sur les boutons filtres */
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      applyFilter(btn.dataset.filter);
    });
  });

  /* Compteur initial */
  updateCount();
</script>

</body>
</html>