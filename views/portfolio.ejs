<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>DevPioneers - Portfolio</title>
  <style>
/* ------------------------------ */
/* RESET & GLOBAL */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: "Poppins", sans-serif;
}
body {
    background: #fefefe;
    color: #222;
}

/* ------------------------------ */
/* HERO */
.portfolio-hero {
    margin-top: 75px;
    text-align: center;
    padding: 100px 20px;
    background: #fafafa;
}

.portfolio-hero h1 {
    font-size: 48px;
    font-weight: 700;
    margin-bottom: 12px;
    color: #1a1a1a;
}

.portfolio-hero p {
    font-size: 18px;
    color: #555;
    max-width: 700px;
    margin: 0 auto;
}

/* ------------------------------ */
/* GRID DES PROJETS */
.projects-grid {
    margin: 60px auto;
    display: grid;
    gap: 35px;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    max-width: 1200px;
}

.project-card {
    background: white;
    border-radius: 16px;
    padding: 18px;
    box-shadow: 0 6px 25px rgba(0,0,0,0.08);
    transition: all .3s ease;
}

.project-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(0,0,0,0.12);
}

.project-card a {
    text-decoration: none;
    color: inherit;
}

.project-image {
    width: 100%;
    height: 180px;
    overflow: hidden;
    border-radius: 12px;
    margin-bottom: 15px;
}

.project-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .3s ease;
}

.project-card:hover img {
    transform: scale(1.05);
}

.project-card h3 {
    font-size: 20px;
    margin-bottom: 8px;
    color: #1a1a1a;
    font-weight: 600;
}

.project-card p {
    font-size: 15px;
    color: #555;
    line-height: 1.5;
}

/* ------------------------------ */
/* CTA */
.call-to-action {
    text-align: center;
    margin: 80px auto;
}

.call-to-action h2 {
    font-size: 28px;
    margin-bottom: 25px;
    color: #1a1a1a;
}

.btn-cta {
    background: #ff6a00;
    padding: 14px 28px;
    color: white;
    font-weight: 600;
    text-decoration: none;
    border-radius: 8px;
    transition: all .3s ease;
}

.btn-cta:hover {
    background: #e95d00;
}

/* ------------------------------ */
/* RESPONSIVE */
@media (max-width: 992px) {
    .portfolio-hero h1 {
        font-size: 38px;
    }
    .project-image {
        height: 160px;
    }
}

@media (max-width: 768px) {
    .portfolio-hero h1 {
        font-size: 32px;
    }
    .portfolio-hero p {
        font-size: 16px;
    }
    .project-image {
        height: 140px;
    }
    .btn-cta {
        padding: 12px 24px;
        font-size: 14px;
    }
}

@media (max-width: 480px) {
    .portfolio-hero h1 {
        font-size: 28px;
    }
    .portfolio-hero p {
        font-size: 15px;
    }
    .projects-grid {
        gap: 20px;
    }
    .project-image {
        height: 120px;
    }
}
</style>

</head>
<body>

  <%- include('utilisables/header') %>

  <main class="portfolio-page">

    <!-- HERO -->
    <section class="portfolio-hero">
      <div class="container">
        <h1>Nos Réalisations</h1>
        <p>
          Découvrez une sélection de nos projets — sites web, applications mobiles et identités visuelles.
        </p>
      </div>
    </section>

    <!-- GRID DES PROJETS -->
    <section class="projects-grid container">
      <% projets.forEach(p => { %>
        <div class="project-card">
          <a href="<%= p.url %>" target="_blank">
            <div class="project-image">
              <img src="https://api.microlink.io?url=<%= p.url %>&screenshot=true&meta=false" alt="<%= p.title %>">

            </div>
            <h3><%= p.title %></h3>
            <p><%= p.description %></p>
          </a>
        </div>
      <% }) %>
    </section>

    <!-- CTA -->
    <section class="call-to-action container">
      <h2>Vous avez un projet en tête ?</h2>
      <a href="/contact" class="btn-cta">Contactez-nous</a>
    </section>

  </main>

  <%- include('utilisables/footer') %>

</body>
</html>
